<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Neural Settings"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Identity Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_stats_bg"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <View
                android:id="@+id/identity_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/brain_shape"
                android:backgroundTint="@color/cyan_glow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tv_identity_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Identity: Digital Monk"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/identity_icon"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tv_identity_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Level 4 - Neural Explorer"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tv_identity_level"
                app:layout_constraintTop_toBottomOf="@id/tv_identity_level"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Custom Message Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Custom Block Message"
            android:textColor="@color/cyan_glow"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etBlockMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_stats_bg"
            android:padding="16dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:hint="Type your custom warning here..."
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <!-- Blocked Apps Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Apps to Restrict"
            android:textColor="@color/cyan_glow"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnBrowseApps"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Browse Apps to Block"
            android:backgroundTint="@color/card_dark"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"
            app:icon="@android:drawable/ic_menu_add"
            app:iconTint="@color/cyan_glow"/>

        <TextView
            android:id="@+id/tvBlockedAppsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_stats_bg"
            android:padding="16dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"/>

        <Button
            android:id="@+id/btnClearApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Clear List"
            android:textColor="@color/magenta_alert"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Save Neural Configuration"
            android:backgroundTint="@color/accent_green"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            app:cornerRadius="28dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
