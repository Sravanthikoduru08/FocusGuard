<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_study_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deep Focus"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp" />

    <!-- 1. Topic Input Layout (Initial State) -->
    <LinearLayout
        android:id="@+id/layout_topic_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_study_title">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What are you studying today?"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/et_topic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., Quantum Physics, Kotlin Coroutines"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/cyan_glow"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Duration (Minutes)"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_duration_20"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="20m"
                android:textColor="@color/white"
                app:strokeColor="@color/cyan_glow" />

            <Button
                android:id="@+id/btn_duration_30"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="30m"
                android:textColor="@color/white"
                app:strokeColor="@color/cyan_glow"
                android:layout_marginHorizontal="8dp" />

            <Button
                android:id="@+id/btn_duration_45"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="45m"
                android:textColor="@color/white"
                app:strokeColor="@color/cyan_glow" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_start_study"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Start Deep Focus"
            android:backgroundTint="#0066FF"
            app:cornerRadius="28dp" />
    </LinearLayout>

    <!-- 2. Timer Layout (Active State) -->
    <FrameLayout
        android:id="@+id/layout_timer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/layout_timer_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_study_title">

        <!-- Outer Soft Glow -->
        <View
            android:id="@+id/timer_glow_outer"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            android:alpha="0.2"
            android:background="@drawable/brain_glow_cyan" />

        <!-- Main Timer Circle Background -->
        <View
            android:id="@+id/timer_circle"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@drawable/brain_shape"
            android:backgroundTint="@color/card_dark" />

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="25:00"
            android:textColor="@color/white"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:text="Time"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_current_topic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="Neural stabilization animation"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </FrameLayout>

    <!-- 3. Question Layout (End State) -->
    <LinearLayout
        android:id="@+id/layout_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_study_title">

        <TextView
            android:id="@+id/tv_ai_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Question will appear here..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/et_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type your answer here"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/cyan_glow"
            android:padding="12dp" />

        <Button
            android:id="@+id/btn_submit_answer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Submit &amp; Finish"
            android:backgroundTint="@color/accent_green"
            app:cornerRadius="28dp" />

        <Button
            android:id="@+id/btn_skip_penalty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Abort Session (-10% XP)"
            android:textColor="@color/white"
            android:backgroundTint="@android:color/transparent"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:id="@+id/layout_timer_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session Progress"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pb_session_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="50"
            android:progressTint="@color/cyan_glow"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_play_pause"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/card_dark"
            android:text="Pause Session"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            app:cornerRadius="28dp"
            app:strokeColor="@color/cyan_glow"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btn_pause"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#33FF007A"
            android:text="Abort Session"
            android:textAllCaps="false"
            android:textColor="@color/magenta_alert"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:strokeColor="@color/magenta_alert"
            app:strokeWidth="1dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
