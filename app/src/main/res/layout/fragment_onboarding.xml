<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#444444"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_onboarding_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What keeps you going?"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="32dp"/>

    <FrameLayout
        android:id="@+id/photo_container"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_onboarding_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_anchor_photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_stats_bg"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tv_upload_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload photo for\nfamily, son, dream, goal"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_gravity="center" />
    </FrameLayout>

    <Button
        android:id="@+id/btn_upload_photo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/card_dark"
        android:text="Upload"
        app:icon="@android:drawable/ic_menu_camera"
        android:textAllCaps="false"
        android:textColor="@color/cyan_glow"
        app:layout_constraintTop_toBottomOf="@id/photo_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_emotional_anchor_setup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Emotional Anchor Setup"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btn_upload_photo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_emotional_anchor_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Emotional anchor identifies photo\nor dream goal"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_emotional_anchor_setup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/et_anchor_quote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_stats_bg"
        android:hint="I build for my family's better tomorrow."
        android:padding="16dp"
        android:textColor="@color/white"
        android:textColorHint="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/tv_emotional_anchor_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#0066FF"
        android:text="Continue"
        android:textAllCaps="false"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
