<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tv_onboarding_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Establish Connection"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="40dp"/>

        <FrameLayout
            android:id="@+id/photo_container"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_onboarding_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_anchor_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/card_stats_bg"
                android:scaleType="centerCrop"
                android:clipToOutline="true" />

            <TextView
                android:id="@+id/tv_upload_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload photo for\nfamily, son, dream, goal"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="16dp"/>
        </FrameLayout>

        <Button
            android:id="@+id/btn_upload_photo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Upload Photo"
            android:textAllCaps="false"
            android:textColor="@color/cyan_glow"
            app:strokeColor="@color/cyan_glow"
            app:layout_constraintTop_toBottomOf="@id/photo_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_emotional_anchor_setup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emotional Anchor Setup"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/btn_upload_photo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_emotional_anchor_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Visual reminders of why you focus help sustain long-term discipline."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_emotional_anchor_setup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/et_anchor_quote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_stats_bg"
            android:hint="Type your motivation here..."
            android:padding="20dp"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tv_emotional_anchor_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="#0066FF"
            android:text="Establish Connection"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="32dp"
            app:layout_constraintTop_toBottomOf="@id/et_anchor_quote"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_skip"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:text="Skip setup for now"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/btn_continue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
