<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ─── HEADER ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊  TEACHER REPORT"
                android:textColor="#00E5FF"
                android:textSize="10sp"
                android:letterSpacing="0.3"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvExportDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7A7A8C"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ─── ROW 1: App Opens + Study Hours ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="10dp">

            <!-- App Opens -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_panel"
                android:padding="16dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱"
                    android:textSize="24sp" />
                <TextView
                    android:id="@+id/tvAppOpenCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00E5FF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Opens"
                    android:textColor="#9090A0"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Study Hours -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_panel"
                android:padding="16dp"
                android:layout_marginStart="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️"
                    android:textSize="24sp" />
                <TextView
                    android:id="@+id/tvTotalStudyHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0h"
                    android:textColor="#A78BFA"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Study Hours"
                    android:textColor="#9090A0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ─── ROW 2: Streak + XP ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="10dp">

            <!-- Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_panel"
                android:padding="16dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="24sp" />
                <TextView
                    android:id="@+id/tvStreakDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#F59E0B"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day Streak"
                    android:textColor="#9090A0"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- XP -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_panel"
                android:padding="16dp"
                android:layout_marginStart="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="24sp" />
                <TextView
                    android:id="@+id/tvTotalXp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#10B981"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total XP"
                    android:textColor="#9090A0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ─── SESSION COMPLETION RATE ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_panel"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎯  Session Completion Rate"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvCompletionRatePct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#00E5FF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pbCompletionRate"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="10dp"
                android:progressDrawable="@drawable/progress_cyan"
                android:max="100"
                android:progress="0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/tvSessionsStarted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Started: 0"
                    android:textColor="#7A7A8C"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvSessionsCompleted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Completed: 0"
                    android:textColor="#10B981"
                    android:textSize="12sp"
                    android:gravity="center" />
                <TextView
                    android:id="@+id/tvSessionsAborted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aborted: 0"
                    android:textColor="#F87171"
                    android:textSize="12sp"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- ─── AVERAGE FOCUS SCORE ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_panel"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🧠  Average Focus Score"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvAvgFocusPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#A78BFA"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pbAvgFocus"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="10dp"
                android:progressDrawable="@drawable/progress_purple"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tvFocusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating..."
                android:textColor="#7A7A8C"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- ─── DISTRACTION CONTROL ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="10dp">

            <!-- Blocked Attempts -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_panel"
                android:padding="16dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚫"
                    android:textSize="24sp" />
                <TextView
                    android:id="@+id/tvBlockedAttempts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#F87171"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blocked Attempts"
                    android:textColor="#9090A0"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Recovery Sessions -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/glass_panel"
                android:padding="16dp"
                android:layout_marginStart="5dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💚"
                    android:textSize="24sp" />
                <TextView
                    android:id="@+id/tvRecoverySessions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#10B981"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recovery Sessions"
                    android:textColor="#9090A0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ─── 7-DAY STUDY BAR CHART ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_panel"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅  Daily Study Time (Last 7 Days)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Bar chart container -->
            <LinearLayout
                android:id="@+id/llBarChart"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:weightSum="7" />

            <!-- Day labels -->
            <LinearLayout
                android:id="@+id/llBarLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:weightSum="7" />
        </LinearLayout>

        <!-- ─── TOPICS STUDIED ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_panel"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚  Topics Studied"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/llTopicsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvNoTopics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No study sessions recorded yet."
                android:textColor="#4A4A5A"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ─── EXPORT BUTTON ─── -->
        <Button
            android:id="@+id/btnExportReport"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⬇  Export Report as JSON"
            android:textColor="#0A0A0F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="8dp" />

        <!-- ─── SHARE BUTTON ─── -->
        <Button
            android:id="@+id/btnShareReport"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📤  Share via WhatsApp / Email"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#1D1D2E"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
