<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tv_analytics_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cognitive Analytics"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_analytics_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Your behavioral insights"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_analytics_title" />

        <!-- Focus Score Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_focus_score"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_stats_bg"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_analytics_subtitle">

            <TextView
                android:id="@+id/label_focus_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overall Focus Score"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_focus_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85%"
                android:textColor="@color/cyan_glow"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/label_focus_score" />

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/brain_glow_cyan"
                android:alpha="0.2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Stats Grid (Sessions, Blocks, etc.) -->
        <GridLayout
            android:id="@+id/analytics_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            app:layout_constraintTop_toBottomOf="@id/card_focus_score">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_stats_bg"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sessions" android:textColor="@color/text_secondary" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="124" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/card_stats_bg"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="App Blocks" android:textColor="@color/text_secondary" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="42" android:textColor="@color/magenta_alert" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <!-- Dopamine Heatmap Placeholder -->
        <TextView
            android:id="@+id/label_heatmap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Dopamine Overload Heatmap"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/analytics_grid" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_heatmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_stats_bg"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/label_heatmap">

            <GridLayout
                android:id="@+id/heatmap_grid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="12"
                android:rowCount="7"
                android:useDefaultMargins="true"
                android:alignmentMode="alignBounds"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/heatmap_legend" />

            <LinearLayout
                android:id="@+id/heatmap_legend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toEndOf="@id/heatmap_grid"
                app:layout_constraintTop_toBottomOf="@id/heatmap_grid"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Less"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"/>

                <View android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/card_dark" android:alpha="0.2"/>
                <View android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/magenta_alert" android:alpha="0.4"/>
                <View android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/purple_glow" android:alpha="0.6"/>
                <View android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/cyan_glow" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Insights -->
        <TextView
            android:id="@+id/label_insights"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Behavioral Insights"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_heatmap" />

        <TextView
            android:id="@+id/tv_insight_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_stats_bg"
            android:padding="16dp"
            android:text="Your attention is most fragmented between 2 PM and 4 PM. Try scheduling a Recovery Protocol during this window."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/label_insights" />

        <Button
            android:id="@+id/btn_manage_blocks"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Configure Block List"
            android:backgroundTint="@color/card_dark"
            android:textColor="@color/cyan_glow"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_insight_text" />

        <Button
            android:id="@+id/btn_teacher_report"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:text="📊  View Teacher Report"
            android:backgroundTint="#00E5FF"
            android:textColor="#0A0A0F"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/btn_manage_blocks"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
